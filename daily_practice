p\": \"කයින් සිදුවන වැරදි වැළකීමට උදෑසන සිහිපත් කරගන්න.\",\n        \"categories\": [\"උදේ කාලයේ\", \"අන් අය සමඟ ගැටුමක් ඇති විට\"]\n      },\n      {\n        \"step\": \"කතා කිරීමට පෙර එම වචන සත්‍යද, ප්‍රියද සහ ඵලදායීදැයි විමසන්න.\",\n        \"categories\": [\"අන් අය සමඟ ගැටුමක් ඇති විට\", \"කාර්යබහුල අවස්ථාවක\"]\n      },\n      {\n        \"step\": \"සිතේ ද්වේෂයක් හෝ දැඩි ආශාවක් ඇතිවන විට එය හඳුනාගෙන මෛත්‍රියෙන් හෝ සම්මා දිට්ඨියෙන් එය සංසිඳවන්න.\",\n        \"categories\": [\"තරහ යන විට\", \"අන් අය සමඟ ගැටුමක් ඇති විට\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"තික නිපාතෝ\",\n    \"vagga\": \"\",\n    \"sutta_title\": \"\",\n    \"id\": \"8023\",\n    \"daily_practise\": [\n      {\n        \"step\": \"දවස පුරා ඔබ අතින් සිදුවන කායික ක්‍රියාවන්හි අවිහිංසාවාදී බව පරීක්ෂා කරන්න.\",\n        \"categories\": [\"කාර්යබහුල අවස්ථාවක\", \"දෑවැද්දක් දැනෙන විට\"]\n      },\n      {\n        \"step\": \"කතා කිරීමට පෙර එම වචන සත්‍යද, මෘදුද සහ ප්‍රයෝජනවත්ද යන්න තත්පරයකට සිතන්න.\",\n        \"categories\": [\"අන් අය සමඟ ගැටුමක් ඇති විට\", \"කාර්යබහුල අවස්ථාවක\"]\n      },\n      {\n        \"step\": \"දිනකට කිහිප වතාවක් සිත දෙස බලා 'දැන් මා තුළ පවතින්නේ කිනම් නීවරණයක්ද?' යන්න හඳුනාගන්න.\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"තනිකමක් දැනෙන විට\"]\n      },\n      {\n        \"step\": \"අකුසල් සිතුවිල්ලක් ආ විට එය ආ බව දැනගෙන, එයට ප්‍රතිචාර නොදක්වා සන්සුන්ව ඉවත් වන්න.\",\n        \"categories\": [\"තරහ යන විට\", \"සිත නොසන්සුන් විට\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"තික නිපාතෝ\",\n    \"vagga\": \"\",\n    \"sutta_title\": \"\",\n    \"id\": \"8024\",\n    \"daily_practise\": [\n      {\n        \"step\": \"කය සහ වචනයෙන් අන් අයට හානි වන දේ නොකිරීමට දැඩිව අධිෂ්ඨාන කරගන්න (Sila).\",\n        \"categories\": [\"අන් අය සමඟ ගැටුමක් ඇති විට\", \"කාර්යබහුල අවස්ථාවක\"]\n      },\n      {\n        \"step\": \"සිතේ උපදින තණ්හාව සහ කෝපය දෙස මධ්‍යස්ථව බැලීමට පුහුණු වන්න (Mindfulness).\",\n        \"categories\": [\"තරහ යන විට\", \"සිත නොසන්සුන් විට\"]\n      },\n      {\n        \"step\": \"සෑම ක්‍රියාවකදීම සිතේ අභිප්‍රාය (Intention) නිරීක්ෂණය කරන්න.\",\n        \"categories\": [\"කාර්යබහුල අවස්ථාවක\", \"දෑවැද්දක් දැනෙන විට\"]\n      },\n      {\n        \"step\": \"දිනපතා කෙටි වෙලාවක් හෝ නිසලව හිඳ ආශ්‍රවයන් නිසා සිත කැලඹෙන ආකාරය වටහා ගන්න.\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"රාත්‍රී නින්දට පෙර\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"තික නිපාතෝ\",\n    \"vagga\": \"\",\n    \"sutta_title\": \"\",\n    \"id\": \"8053\",\n    \"daily_practise\": [\n      {\n        \"step\": \"ආහාරයක් හෝ පහසුවක් ලැබුණු විට 'මම මෙයට ඇලී සිටිනවාද?' යන්න තත්පර කිහිපයක් මෙනෙහි කරන්න.\",\n        \"categories\": [\"සතුටු වන විට\", \"දෑවැද්දක් දැනෙන විට\"]\n      },\n      {\n        \"step\": \"පරිභෝජනය කරන්නේ ශරීරයේ පැවැත්මට මිස රාගය වැඩි කර ගැනීමට නොවන බව සිතන්න.\",\n        \"categories\": [\"උදේ කාලයේ\", \"කාර්යබහුල අවස්ථාවක\"]\n      },\n      {\n        \"step\": \"ඕනෑම ලාභයක හෝ ප්‍රශංසාවක ඇති ආදීනව (අස්ථිර බව) දකින්න.\",\n        \"categories\": [\"සතුටු වන විට\", \"සිත නොසන්සුන් විට\"]\n      },\n      {\n        \"step\": \"සෑම ක්‍රියාවකදීම 'අප්‍රමාදය' හෙවත් සතිමත් බව පවත්වා ගන්න.\",\n        \"categories\": [\"කාර්යබහුල අවස්ථාවක\", \"දෑවැද්දක් දැනෙන විට\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"තික නිපාතෝ\",\n    \"vagga\": \"\",\n    \"sutta_title\": \"\",\n    \"id\": \"8054\",\n    \"daily_practise\": [\n      {\n        \"step\": \"දවස පුරා සිතට එන සිතුවිලි දෙස අවධානයෙන් සිටීම (Thought monitoring).\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"කාර්යබහුල අවස්ථාවක\"]\n      },\n      {\n        \"step\": \"අමනාපයක් ඇති වූ විට එය ව්‍යාපාද විතර්කයක් ලෙස හඳුනාගෙන අත්හැරීම.\",\n        \"categories\": [\"අන් අය සමඟ ගැටුමක් ඇති විට\", \"දුකක්/කනගාටුවක් ඇති විට\"]\n      },\n      {\n        \"step\": \"අන් අය දෙස කරුණාවෙන් සහ දයාවෙන් බැලීම දිනපතා පුහුණු කිරීම (Metta practice).\",\n        \"categories\": [\"දුකක්/කනගාටුවක් ඇති විට\", \"අන් අය සමඟ ගැටුමක් ඇති විට\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"තික නිපාතෝ\",\n    \"vagga\": \"\",\n    \"sutta_title\": \"\",\n    \"id\": \"8055\",\n    \"daily_practise\": [\n      {\n        \"step\": \"අන්ධ විශ්වාසයෙන් තොරව කරුණු විමසා බැලීම.\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"තනිකමක් දැනෙන විට\"]\n      },\n      {\n        \"step\": \"තමා කරන ක්‍රියාවන්හි හේතුව සහ ඵලය (Cause and Effect) නිරීක්ෂණය කිරීම.\",\n        \"categories\": [\"කාර්යබහුල අවස්ථාවක\", \"දෑවැද්දක් දැනෙන විට\"]\n      },\n      {\n        \"step\": \"ධර්මය ප්‍රායෝගිකව අත්හදා බලා ලැබෙන මානසික සහනය (ප්‍රාතිහාර්යය) අත්දැකීම.\",\n        \"categories\": [\"දුකක්/කනගාටුවක් ඇති විට\", \"සිත නොසන්සුන් විට\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"තික නිපාතෝ\",\n    \"vagga\": \"\",\n    \"sutta_title\": \"\",\n    \"id\": \"8056\",\n    \"daily_practise\": [\n      {\n        \"step\": \"තමා අත්දකින වේදනාවක් හෝ සැපයක් දැනෙන විට එය පිරිසිඳ අවබෝධ කරගැනීමට මොහොතක් නතර වන්න.\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"දුකක්/කනගාටුවක් ඇති විට\"]\n      },\n      {\n        \"step\": \"බාහිර ලෝකය (රූප) කෙරෙහි ඇති බැඳීම් වල පවතින සීමිත බව මෙනෙහි කරන්න.\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"තනිකමක් දැනෙන විට\"]\n      },\n      {\n        \"step\": \"විවිධ මතයන් අතර සැබෑ යථාර්ථය හඳුනා ගැනීමට විමර්ශනාත්මකව කටයුතු කරන්න.\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"තනිකමක් දැනෙන විට\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"තික නිපාතෝ\",\n    \"vagga\": \"\",\n    \"sutta_title\": \"\",\n    \"id\": \"8057\",\n    \"daily_practise\": [\n      {\n        \"step\": \"දිනපතා සුළු වෙලාවක් හෝ ධර්ම කරුණක් කියවීමට හෝ ශ්‍රවණය කිරීමට වෙන් කරන්න.\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"තනිකමක් දැනෙන විට\"]\n      },\n      {\n        \"step\": \"පින්කමක් හෝ උදවුවක් කළ පසු ඉන් ලැබෙන මානසික සතුට තවදුරටත් ගුණධර්ම වැඩීමට උත්තේජනයක් කර ගන්න.\",\n        \"categories\": [\"සතුටු වන විට\", \"උදේ කාලයේ\"]\n      },\n      {\n        \"step\": \"තමා දන්නා ධර්මය අන් අය සමඟ බෙදා ගැනීමට උත්සාහ කරන්න.\",\n        \"categories\": [\"අන් අය සමඟ ගැටුමක් ඇති විට\", \"තනිකමක් දැනෙන විට\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"තික නිපාතෝ\",\n    \"vagga\": \"\",\n    \"sutta_title\": \"\",\n    \"id\": \"8058\",\n    \"daily_practise\": [\n      {\n        \"step\": \"බාහිර රූප හෝ ශබ්ද කෙරෙහි පමණට වඩා ඇලීමෙන් වළකින්න (ඉන්ද්‍රිය සංවරය).\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"කාර්යබහුල අවස්ථාවක\"]\n      },\n      {\n        \"step\": \"සිතේ ක්‍රෝධයක් හෝ අසතුටක් උපදින විට එය 'පිළී ගඳක්' ලෙස හඳුනාගෙන වහාම මැඩපවත්වන්න.\",\n        \"categories\": [\"තරහ යන විට\", \"අන් අය සමඟ ගැටුමක් ඇති විට\"]\n      },\n      {\n        \"step\": \"අකුසල් සිතිවිලි (මැස්සන්) රොද බඳින්නට පෙර 'සති' (Mindfulness) සිහිය පිහිටුවා ගන්න.\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"කාර්යබහුල අවස්ථාවක\"]\n      },\n      {\n        \"step\": \"තමාගේ ප්‍රගතිය විවේචනාත්මකව සහ ප්‍රඥාවන්තව පිරික්සන කල්‍යාණ මිත්‍ර උපදෙස් පිළිපදින්න.\",\n        \"categories\": [\"දෑවැද්දක් දැනෙන විට\", \"සිත නොසන්සුන් විට\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"තික නිපාතෝ\",\n    \"vagga\": \"\",\n    \"sutta_title\": \"\",\n    \"id\": \"8059\",\n    \"daily_practise\": [\n      {\n        \"step\": \"උදෑසන අවදි වූ විට සිතේ පවතින සිතුවිලි පිළිබඳ සතිමත් (Mindful) වීම.\",\n        \"categories\": [\"උදේ කාලයේ\", \"සිත නොසන්සුන් විට\"]\n      },\n      {\n        \"step\": \"මසුරුකම ඇතිවන අවස්ථාවලදී කුඩා හෝ දෙයක් අනුන්ට දීමට උත්සාහ කිරීම.\",\n        \"categories\": [\"අන් අය සමඟ ගැටුමක් ඇති විට\", \"තනිකමක් දැනෙන විට\"]\n      },\n      {\n        \"step\": \"දවස පුරා සිතේ පවතින සෘණාත්මක ස්වභාවය නිරීක්ෂණය කර එය කුසලයකට හැරවීම.\",\n        \"categories\": [\"කාර්යබහුල අවස්ථාවක\", \"තරහ යන විට\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"තික නිපාතෝ\",\n    \"vagga\": \"\",\n    \"sutta_title\": \"\",\n    \"id\": \"8060\",\n    \"daily_practise\": [\n      {\n        \"step\": \"තම දක්ෂතා ගැන සිතෙන විට එය 'සිතුවිල්ලක් පමණයි' (Just a thought) ලෙස හඳුනාගන්න.\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"තනිකමක් දැනෙන විට\"]\n      },\n      {\n        \"step\": \"මානය හෝ විසිරීම ඇතිවන විට, ඒවායේ ඇලෙන්නේ නැතිව සිත නැවත නිහඬ අරමුණකට (උදා: ආශ්වාස ප්‍රශ්වාසය) යොමු කරන්න.\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"කාර්යබහුල අවස්ථාවක\"]\n      },\n      {\n        \"step\": \"තමා අන් අයට වඩා උසස් හෝ පහත් යැයි සසඳන ස්වභාවය අවබෝධයෙන් යුතුව අත්හරින්න.\",\n        \"categories\": [\"තනිකමක් දැනෙන විට\", \"අන් අය සමඟ ගැටුමක් ඇති විට\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"තික නිපාතෝ\",\n    \"vagga\": \"\",\n    \"sutta_title\": \"\",\n    \"id\": \"8061\",\n    \"daily_practise\": [\n      {\n        \"step\": \"තම සිත තුළ ඇති වැරදි මත හඳුනාගෙන ඒවා විවෘතව ප්‍රශ්න කරන්න.\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"තනිකමක් දැනෙන විට\"]\n      },\n      {\n        \"step\": \"ධර්මය හැදෑරීමේදී එහි අර්ථය පැහැදිලිව විවෘත කර ගැනීමට උත්සාහ කරන්න.\",\n        \"categories\": [\"උදේ කාලයේ\", \"සිත නොසන්සුන් විට\"]\n      },\n      {\n        \"step\": \"හිරු සඳු මෙන් තම චරිතය විවෘත සහ අවංක මට්ටමක තබා ගන්න.\",\n        \"categories\": [\"අන් අය සමඟ ගැටුමක් ඇති විට\", \"කාර්යබහුල අවස්ථාවක\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"තික නිපාතෝ\",\n    \"vagga\": \"\",\n    \"sutta_title\": \"\",\n    \"id\": \"8062\",\n    \"daily_practise\": [\n      {\n        \"step\": \"අමනාපයක් ඇති වූ සැණින් එය 'ජලයේ ඇඳි ඉරක්' යැයි සිහිපත් කරන්න.\",\n        \"categories\": [\"අන් අය සමඟ ගැටුමක් ඇති විට\", \"දුකක්/කනගාටුවක් ඇති විට\"]\n      },\n      {\n        \"step\": \"පැරණි වෛරයන් මෙනෙහි කිරීම (Rumination) නවත්වන්න.\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"දුකක්/කනගාටුවක් ඇති විට\"]\n      },\n      {\n        \"step\": \"අපහාස හමුවේ සිනහවකින් යුතුව ප්‍රතිචාර දක්වන්න.\",\n        \"categories\": [\"අන් අය සමඟ ගැටුමක් ඇති විට\", \"කාර්යබහුල අවස්ථාවක\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"උපරි පණ්ණාසකෝ\",\n    \"vagga\": \"භද්දේකරත්ත සුත්තං\",\n    \"sutta_title\": \"සොඳුරු හුදෙකලාවෙහි ඇලී සිටීම ගැන වදාළ දෙසුම\",\n    \"id\": \"807\",\n    \"daily_practise\": [\n      {\n        \"step\": \"දිනකට කිහිප වතාවක් සිත අතීතයට හෝ අනාගතයට ගොස් ඇත්දැයි පරීක්ෂා කරන්න (Self-monitoring).\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"තනිකමක් දැනෙන විට\"]\n      },\n      {\n        \"step\": \"එසේ ගොස් ඇත්නම්, වහාම හුස්ම හෝ කරන කාර්යය වෙත අවධානය රැගෙන එන්න (Refocusing).\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"කාර්යබහුල අවස්ථාවක\"]\n      },\n      {\n        \"step\": \"මම පෙර මෙසේ වූයෙමි වැනි අතීත අනන්‍යතාවලින් සිත නිදහස් කරගන්න.\",\n        \"categories\": [\"තනිකමක් දැනෙන විට\", \"සිත නොසන්සුන් විට\"]\n      },\n      {\n        \"step\": \"වර්තමානයේ සිදුවන ශාරීරික සහ මානසික වෙනස්වීම් දෙස විමර්ශනාත්මකව බලන්න.\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"සත්වයෙකුගේ සෞඛ්‍යය ගැන සිතන විට\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"උපරි පණ්ණාසකෝ\",\n    \"vagga\": \"ආනන්ද භද්දේකරත්ත සුත්තං\",\n    \"sutta_title\": \"සොඳුරු හුදෙකලාවෙහි ඇලී සිටීම ගැන ආනන්ද තෙරුන්ට වදාළ දෙසුම\",\n    \"id\": \"808\",\n    \"daily_practise\": [\n      {\n        \"step\": \"අතීතය ගැන සිතක් ඇති වූ විට 'මෙය දැන් අවසන් වූ රූප/වේදනාවකි' ලෙස හඳුනා ගන්න.\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"දුකක්/කනගාටුවක් ඇති විට\"]\n      },\n      {\n        \"step\": \"අනාගතය ගැන සැළසුම් කරන විට ඒ කෙරෙහි ඇලීමකින් තොරව සිහියෙන් යුතුව කටයුතු කරන්න.\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"කාර්යබහුල අවස්ථාවක\"]\n      },\n      {\n        \"step\": \"සෑම මොහොතකම සිත කොහේදැයි විමසිලිමත් වන්න.\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"රාත්‍රී නින්දට පෙර\"]\n      }\n    ]\n  }\n]"

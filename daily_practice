\",\n        \"categories\": [\"උදේ කාලයේ\", \"තනිකමක් දැනෙන විට\"]\n      },\n      {\n        \"step\": \"බාහිර බලවේගවලට දොස් පැවරීම වෙනුවට තමාගේ වගකීම (Responsibility) භාර ගැනීමට පුරුදු වන්න.\",\n        \"categories\": [\"අන් අය සමඟ ගැටුමක් ඇති විට\", \"කාර්යබහුල අවස්ථාවක\"]\n      },\n      {\n        \"step\": \"කුඩා හෝ කුසල ක්‍රියාවක නිරත වෙමින් එහි ඵලය නිරීක්ෂණය කරන්න.\",\n        \"categories\": [\"දවස පුරා\", \"සිත නොසන්සුන් විට\"]\n      },\n      {\n        \"step\": \"අකර්මන්‍ය කරන අදහස් සහ ආශ්‍රයෙන් ඈත් වන්න.\",\n        \"categories\": [\"තීරණයක් ගැනීමට පෙර\", \"සිත නොසන්සුන් විට\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"තික නිපාතෝ\",\n    \"vagga\": \"\",\n    \"sutta_title\": \"\",\n    \"id\": \"8095\",\n    \"daily_practise\": [\n      {\n        \"step\": \"පදනමක් සහිත විශ්වාසයකින් දවස අරඹන්න.\",\n        \"categories\": [\"උදේ කාලයේ\", \"සිත නොසන්සුන් විට\"]\n      },\n      {\n        \"step\": \"කය සහ වචනය අකුසලයෙන් මුදවා ගැනීමට නිරන්තර සිහියෙන් පසුවන්න.\",\n        \"categories\": [\"දවස පුරා\", \"අන් අය සමඟ ගැටුමක් ඇති විට\"]\n      },\n      {\n        \"step\": \"ඕනෑම සිදුවීමක අනිත්‍ය ස්වභාවය විමසමින් ප්‍රඥාව පුහුණු කරන්න.\",\n        \"categories\": [\"දුකක්/කනගාටුවක් ඇති විට\", \"සිත නොසන්සුන් විට\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"තික නිපාතෝ\",\n    \"vagga\": \"\",\n    \"sutta_title\": \"\",\n    \"id\": \"8096\",\n    \"daily_practise\": [\n      {\n        \"step\": \"සෑම උදෑසනකම තමා අනුගමනය කරන උසස් ප්‍රතිපත්ති සිහිපත් කරමින් ශ්‍රද්ධාව ඇති කර ගැනීම.\",\n        \"categories\": [\"උදේ කාලයේ\", \"සිත නොසන්සුන් විට\"]\n      },\n      {\n        \"step\": \"දවස පුරා තමාගේ වචනය සහ ක්‍රියාව අන් අයට පීඩාවක් නොවන පරිදි සීලයක පිහිටා පවත්වා ගැනීම.\",\n        \"categories\": [\"දවස පුරා\", \"අන් අය සමඟ ගැටුමක් ඇති විට\"]\n      },\n      {\n        \"step\": \"සිදුවන සෑම සිදුවීමකදීම එහි අනිත්‍යතාවය හෝ හේතු-ඵල සබඳතාවය ප්‍රඥාවෙන් යුතුව විමසා බැලීම.\",\n        \"categories\": [\"දුකක්/කනගාටුවක් ඇති විට\", \"සිත නොසන්සුන් විට\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"තික නිපාතෝ\",\n    \"vagga\": \"\",\n    \"sutta_title\": \"\",\n    \"id\": \"8097\",\n    \"daily_practise\": [\n      {\n        \"step\": \"දිනපතා සතිමත් බව (Mindfulness) පුහුණු කිරීම.\",\n        \"categories\": [\"දවස පුරා\", \"කාර්යබහුල අවස්ථාවක\"]\n      },\n      {\n        \"step\": \"ධර්ම කරුණු හෝ විෂය කරුණු ගැඹුරින් අධ්‍යයනය කර තර්කානුකූලව විමසීම.\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"තීරණයක් ගැනීමට පෙර\"]\n      },\n      {\n        \"step\": \"තමා අනුගමනය කරන ශීලය හෝ විනයානුකූල පැවැත්ම පිළිබඳ අවධානය යොමු කිරීම.\",\n        \"categories\": [\"දවස පුරා\", \"කාර්යබහුල අවස්ථාවක\"]\n      },\n      {\n        \"step\": \"තමා තුළ ඇති අඩුපාඩු හඳුනාගෙන ඒවා ක්‍රමයෙන් නිවැරදි කරගැනීම.\",\n        \"categories\": [\"තමා ගැන සිතන විට\", \"උදේ කාලයේ\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"තික නිපාතෝ\",\n    \"vagga\": \"\",\n    \"sutta_title\": \"\",\n    \"id\": \"8098\",\n    \"daily_practise\": [\n      {\n        \"step\": \"තමා සතු අධ්‍යාත්මික වීර්යය (ජවය) හඳුනාගෙන එය පෝෂණය කරන්න.\",\n        \"categories\": [\"උදේ කාලයේ\", \"තනිකමක් දැනෙන විට\"]\n      },\n      {\n        \"step\": \"ධර්ම කරුණු ශ්‍රවණය සහ විමර්ශනය මගින් ප්‍රඥාව (වර්ණය) වර්ධනය කරගන්න.\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"තීරණයක් ගැනීමට පෙර\"]\n      },\n      {\n        \"step\": \"පවතින සම්පත් (පිරිකර) පිළිබඳ තෘප්තිමත් වෙමින් මානසික සමබරතාව පවත්වා ගන්න.\",\n        \"categories\": [\"දුකක්/කනගාටුවක් ඇති විට\", \"කාර්යබහුල අවස්ථාවක\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"තික නිපාතෝ\",\n    \"vagga\": \"\",\n    \"sutta_title\": \"\",\n    \"id\": \"8099\",\n    \"daily_practise\": [\n      {\n        \"step\": \"සිතේ උපදින කෙලෙස් (ආශ්‍රව) හඳුනා ගැනීමට සතිමත් වන්න.\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"දවස පුරා\"]\n      },\n      {\n        \"step\": \"ධර්ම කරුණු පිළිබඳව ගැඹුරින් සොයා බලා බුද්ධිමය අවබෝධය (වර්ණය) වර්ධනය කරගන්න.\",\n        \"categories\": [\"තීරණයක් ගැනීමට පෙර\", \"සිත නොසන්සුන් විට\"]\n      },\n      {\n        \"step\": \"භෞතික අවශ්‍යතා ලැබෙන ප්‍රමාණයෙන් සතුටු වෙමින් ඒවා අවම ලෙස පරිහරණය කරන්න.\",\n        \"categories\": [\"දුකක්/කනගාටුවක් ඇති විට\", \"කාර්යබහුල අවස්ථාවක\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"උපරි පණ්ණාසකෝ\",\n    \"vagga\": \"ලෝමසකංගිය භද්දේකරත්ත සුත්තං\",\n    \"sutta_title\": \"සොඳුරු හුදෙකලාවෙහි ඇලී සිටීම ගැන ලෝමසකංගිය තෙරුන්ට වදාළ දෙසුම\",\n    \"id\": \"810\",\n    \"daily_practise\": [\n      {\n        \"step\": \"සිත අතීතයට හෝ අනාගතයට දිව යන සැමවිටම 'අතීතය ගෙවී ඇත, අනාගතය පැමිණ නැත' යනුවෙන් මෙනෙහි කරන්න.\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"තනිකමක් දැනෙන විට\"]\n      },\n      {\n        \"step\": \"වර්තමාන මොහොතේ සිතේ ඇතිවන ඕනෑම ආශාවක් හෝ ගැටීමක් දෙස උපේක්ෂාවෙන් බැලීමට පුහුණු වන්න.\",\n        \"categories\": [\"දවස පුරා\", \"කාර්යබහුල අවස්ථාවක\"]\n      },\n      {\n        \"step\": \"දිනකට සුළු වේලාවක් හෝ හුදෙකලා වී, බාහිර ලෝකය සමඟ නොව තමාගේ සිත සමඟ පමණක් සතිමත්ව කාලය ගත කරන්න.\",\n        \"categories\": [\"රාත්‍රී නින්දට පෙර\", \"තනිකමක් දැනෙන විට\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"තික නිපාතෝ\",\n    \"vagga\": \"\",\n    \"sutta_title\": \"\",\n    \"id\": \"8100\",\n    \"daily_practise\": [\n      {\n        \"step\": \"තම වචනය සහ ක්‍රියාව අනුන්ට හානි නොවන පරිදි පවත්වා ගැනීම (සීල පුහුණුව).\",\n        \"categories\": [\"දවස පුරා\", \"අන් අය සමඟ ගැටුමක් ඇති විට\"]\n      },\n      {\n        \"step\": \"දිනකට සුළු වේලාවක් හෝ සිත එකඟ කර ගැනීමට භාවනාවක නිරත වීම (සමාධි පුහුණුව).\",\n        \"categories\": [\"රාත්‍රී නින්දට පෙර\", \"සිත නොසන්සුන් විට\"]\n      },\n      {\n        \"step\": \"ඕනෑම සිදුවීමක අනිත්‍ය බව සහ යථාර්ථය තේරුම් ගැනීමට උත්සාහ කිරීම (ප්‍රඥා පුහුණුව).\",\n        \"categories\": [\"දුකක්/කනගාටුවක් ඇති විට\", \"සිත නොසන්සුන් විට\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"තික නිපාතෝ\",\n    \"vagga\": \"\",\n    \"sutta_title\": \"\",\n    \"id\": \"8101\",\n    \"daily_practise\": [\n      {\n        \"step\": \"ධර්ම අනුශාසනා වලට සවන් දී ඒවා ජීවිතයට ගලපා ගැනීම.\",\n        \"categories\": [\"කාර්යබහුල අවස්ථාවක\", \"තීරණයක් ගැනීමට පෙර\"]\n      },\n      {\n        \"step\": \"තමාගේ සිතේ ඇති වන බන්ධන (ආශාව, තරහව) හඳුනාගෙන ඒවා ලිහා දැමීමට උත්සාහ කිරීම.\",\n        \"categories\": [\"තරහ යන විට\", \"සිත නොසන්සුන් විට\"]\n      },\n      {\n        \"step\": \"දිනපතා සුළු වේලාවක් හෝ මානසික නිස්කලංකත්වය පුහුණු කිරීම.\",\n        \"categories\": [\"රාත්‍රී නින්දට පෙර\", \"තනිකමක් දැනෙන විට\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"තික නිපාතෝ\",\n    \"vagga\": \"\",\n    \"sutta_title\": \"\",\n    \"id\": \"8102\",\n    \"daily_practise\": [\n      {\n        \"step\": \"තමා දකින සහ අසන දේ නිවැරදි දැක්මකින් (සම්මා දිට්ඨියෙන්) යුතුව විමසා බැලීම.\",\n        \"categories\": [\"තීරණයක් ගැනීමට පෙර\", \"සිත නොසන්සුන් විට\"]\n      },\n      {\n        \"step\": \"දේවල් පිළිබඳව ඇතිවන අනවශ්‍ය බැඳීම් සහ ගැටීම් (කෙලෙස්) හඳුනාගෙන ඒවා ලිහිල් කිරීමට උත්සාහ කිරීම.\",\n        \"categories\": [\"දුකක්/කනගාටුවක් ඇති විට\", \"සිත නොසන්සුන් විට\"]\n      },\n      {\n        \"step\": \"දෛනිකව අවම වශයෙන් විනාඩි 10ක්වත් තමාගේ සිතේ ස්වභාවය පිළිබඳ නිවැරදි අවබෝධයක් (සම්මා ඤාණය) ඇති කර ගැනීමට භාවනාවක යෙදීම.\",\n        \"categories\": [\"උදේ කාලයේ\", \"රාත්‍රී නින්දට පෙර\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"උපරි පණ්ණාසකෝ\",\n    \"vagga\": \"චූළ කම්මවිභංග සුත්තං\",\n    \"sutta_title\": \"කර්ම විග්‍රහය ගැන වදාළ කෙටි දෙසුම\",\n    \"id\": \"811\",\n    \"daily_practise\": [\n      {\n        \"step\": \"ඕනෑම ජීවියෙකුට හිංසා කිරීමෙන් වැළකී සිටීම.\",\n        \"categories\": [\"දවස පුරා\", \"අන් අය සමඟ ගැටුමක් ඇති විට\"]\n      },\n      {\n        \"step\": \"කෝපය ඇතිවන අවස්ථාවලදී එය ක්ෂණිකව හඳුනාගෙන ඉවසීම පුහුණු කිරීම.\",\n        \"categories\": [\"තරහ යන විට\", \"අන් අය සමඟ ගැටුමක් ඇති විට\"]\n      },\n      {\n        \"step\": \"අනුන්ගේ දියුණුවේදී අවංකවම සතුටු වීම (මුදිතාව).\",\n        \"categories\": [\"තනිකමක් දැනෙන විට\", \"අන් අය සමඟ ගැටුමක් ඇති විට\"]\n      },\n      {\n        \"step\": \"වැඩිහිටියන්ට සහ ගුණවත් අයට ගෞරව කිරීම සහ නිහතමානී වීම.\",\n        \"categories\": [\"දවස පුරා\", \"අන් අය සමඟ ගැටුමක් ඇති විට\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"උපරි පණ්ණාසකෝ\",\n    \"vagga\": \"මහා කම්මවිභංග සුත්තං\",\n    \"sutta_title\": \"කර්ම විග්‍රහය ගැන වදාළ විස්තරාත්මක දෙසුම\",\n    \"id\": \"812\",\n    \"daily_practise\": [\n      {\n        \"step\": \"වෙනත් පුද්ගලයන් පිළිබඳව තීන්දු තීරණ දීමේදී හෝ විනිශ්චය කිරීමේදී 'දෘෂ්ටි උපාදානයෙන්' තොර වන්න.\",\n        \"categories\": [\"අන් අය සමඟ ගැටුමක් ඇති විට\", \"තීරණයක් ගැනීමට පෙර\"]\n      },\n      {\n        \"step\": \"තමන් අතින් අතීතයේ වූ වැරදි ගැන පසුතැවෙනවා වෙනුවට (Rumination), වර්තමාන මොහොතේ සිත තුළ සම්මා දිට්ඨිය වර්ධනය කරන්න.\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"දුකක්/කනගාටුවක් ඇති විට\"]\n      },\n      {\n        \"step\": \"සෑම ක්‍රියාවකම විපාකය සරල එකක් නොවන බව වටහාගෙන, අකුසලයෙන් වැළකී කුසලයෙහි නිරත වීමට උනන්දු වන්න.\",\n        \"categories\": [\"දවස පුරා\", \"කාර්යබහුල අවස්ථාවක\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"උපරි පණ්ණාසකෝ\",\n    \"vagga\": \"සළායතන විභංග සුත්තං\",\n    \"sutta_title\": \"ආයතන හය පිළිබඳ විග්‍රහ කොට වදාළ දෙසුම\",\n    \"id\": \"813\",\n    \"daily_practise\": [\n      {\n        \"step\": \"ඕනෑම රූපයක්, ශබ්දයක් හෝ රසයක් ලැබෙන විට එය ලැබුණේ ආයතන සහ ස්පර්ශය නිසා බව සිහි කරන්න.\",\n        \"categories\": [\"දවස පුරා\", \"සිත නොසන්සුන් විට\"]\n      },\n      {\n        \"step\": \"ඒ පිළිබඳව සිතේ ඇතිවන සතුට හෝ දුක ගිහි බැඳීමක්ද (ගේහසිත) නැතිනම් යථාර්ථය දැකීමක්දැයි විමසන්න.\",\n        \"categories\": [\"දුකක්/කනගාටුවක් ඇති විට\", \"සිත නොසන්සුන් විට\"]\n      },\n      {\n        \"step\": \"සියල්ල අනිත්‍ය බව සිහි කරමින් සිත මධ්‍යස්ථ තත්ත්වයක (උපේක්ෂාවක) පවත්වා ගැනීමට උත්සාහ කරන්න.\",\n        \"categories\": [\"දවස පුරා\", \"සිත නොසන්සුන් විට\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"උපරි පණ්ණාසකෝ\",\n    \"vagga\": \"උද්දේස විභංග සුත්තං\",\n    \"sutta_title\": \"මූලික දෙසුම විස්තර විභාග වශයෙන් වදාළ දෙසුම\",\n    \"id\": \"814\",\n    \"daily_practise\": [\n      {\n        \"step\": \"ඉන්ද්‍රිය අරමුණක් ලැබුණු සැනින් එහි 'ආශ්වාදය' දෙස මධ්‍යස්ථව බැලීම.\",\n        \"categories\": [\"දවස පුරා\", \"කාර්යබහුල අවස්ථාවක\"]\n      },\n      {\n        \"step\": \"සිතේ ඇතිවන ඕනෑම සුවදායී හැඟීමක් කෙරෙහි වුවද තදින් ඇලී නොසිටීමට වගබලා ගැනීම.\",\n        \"categories\": [\"සිත නොසන්සුන් විට\", \"තනිකමක් දැනෙන විට\"]\n      },\n      {\n        \"step\": \"සිත විසිරෙන අවස්ථාවලදී එය අරමුණක ගිජු වී ඇති ආකාරය සිහියෙන් විමසීම.\",\n        \"categories\": [\"දවස පුරා\", \"කාර්යබහුල අවස්ථාවක\"]\n      }\n    ]\n  },\n  {\n    \"nikaya\": \"තික නිපාතෝ\",\n    \"vagga\": \"\",\n    \"sutta_title\": \"\",\n    \"id\": \"8141\",\n    \"daily_practise\": [\n      {\n        \"step\": \"උදෑසන අවදි වූ විට 'අද දවසේ මගේ කය, වචනය සහ මනස අවිහිංසාවාදීව තබා ගනිමි' යන්න අධිෂ්ඨානය කරන්න.\",\n        \"categories\": [\"උදේ කාලයේ\", \"කාර්යබහුල අවස්ථාවක\"]\n      },\n      {\n        \"step\": \"යම් ක්‍රියාවක් කිරීමට පෙර හෝ වචනයක් පැවසීමට පෙර 'මෙය කුසලයක්ද අකුසලයක්ද' යන්න තත්පර කිහිපයක් සිතන්න (Pause & Reflect).\",\n        \"categories\": [\"අන් අය සමඟ ගැටුමක් ඇති විට\", \"තීරණයක් ගැනීමට පෙර\"]\n      },\n      {\n        \"step\": \"රාත්‍රී නින්දට පෙර දවසේ සිදු වූ වැරදි නිවැරදි කර ගැනීමටත්, කුසලයන් ගැන සතුටු වීමටත් (මුදිතා) පුරුදු වන්න.\",\n        \"categories\": [\"රාත්‍රී නින්දට පෙර\", \"දුකක්/කනගාටුවක් ඇති විට\"]\n      }\n    ]\n  }\n]\n"
